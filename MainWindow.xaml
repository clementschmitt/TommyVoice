<Window x:Class="TommyVoice.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TommyVoice"
        mc:Ignorable="d"
        Title="Tommy Shelby" Height="600" Width="900"
        Background="#1E1E1E">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Zone de conversation -->
        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" Margin="0,0,0,10">
            <TextBox x:Name="ConversationBox"
                     IsReadOnly="True"
                     TextWrapping="Wrap"
                     Background="#2D2D2D"
                     Foreground="White"
                     FontSize="14"
                     Padding="10"
                     BorderThickness="0"
                     Text="Tommy Shelby — en attente..."/>
        </ScrollViewer>

        <!-- Zone de statut -->
        <TextBlock x:Name="StatusLabel"
                   Grid.Row="1"
                   Text="Prêt"
                   Foreground="#888888"
                   FontSize="12"
                   Margin="0,0,0,10"/>

        <!-- Bouton micro -->
        <Button x:Name="RecordButton"
                Grid.Row="2"
                Content="🎙 Parler"
                Height="50"
                FontSize="16"
                Background="#C8A84B"
                Foreground="Black"
                FontWeight="Bold"
                BorderThickness="0"
                Cursor="Hand"
                Click="RecordButton_Click"/>
    </Grid>
</Window>